PORT=4000
FIRESTORE_OT_COLLECTION=ordenes_trabajo
FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com

# Opcion 1: ruta al JSON de cuenta de servicio descargado desde Firebase.
FIREBASE_SERVICE_ACCOUNT_PATH=D:\CODE\OT_TECNINORTE\server\firebase-service-account.json

# Opcion 2: tambien puedes usar la variable oficial de Google.
# GOOGLE_APPLICATION_CREDENTIALS=D:\CODE\OT_TECNINORTE\server\firebase-service-account.json

# Opcion 3: JSON completo en una variable, util para despliegues.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
